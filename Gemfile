source "https://rubygems.org"

gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-sitemap"
  gem "jekyll-seo-tag"
end

gem "webrick", "~> 1.8"

# Ruby 3.4+ removed these from the default stdlib; Jekyll 3.x (pinned by
# github-pages) still requires them. Safe to keep on any Ruby version.
gem "csv"
gem "base64"
gem "bigdecimal"
gem "logger"
gem "ostruct"
